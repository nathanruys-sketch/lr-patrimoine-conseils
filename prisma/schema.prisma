// Prisma schema — LR Patrimoine Conseils
// Learn more: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
}

enum ServiceCategory {
  FISCALITE
  IMMOBILIER
  EPARGNE
  RETRAITE
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  CONVERTED
  ARCHIVED
}

enum LeadSource {
  CONTACT_FORM
  SIMULATEUR_RENDEMENT
  SIMULATEUR_DEFISCALISATION
  SIMULATEUR_RETRAITE
  RENDEZ_VOUS
  AUTRE
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}

enum SimulationType {
  RENDEMENT_LOCATIF
  DEFISCALISATION
  RETRAITE
}

model AdminUser {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String
  role         UserRole @default(ADMIN)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("admin_users")
}

model Service {
  id               String          @id @default(cuid())
  slug             String          @unique
  category         ServiceCategory
  title            String
  shortDescription String
  description      String          @db.Text
  icon             String
  highlights       String[]        @default([])
  order            Int             @default(0)
  published        Boolean         @default(true)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  leads Lead[]

  @@index([category])
  @@map("services")
}

model Testimonial {
  id             String   @id @default(cuid())
  authorName     String
  authorLocation String?
  authorAge      Int?
  content        String   @db.Text
  rating         Int      @default(5)
  source         String?
  published      Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("testimonials")
}

model Lead {
  id        String     @id @default(cuid())
  name      String
  email     String
  phone     String?
  message   String     @db.Text
  status    LeadStatus @default(NEW)
  source    LeadSource @default(CONTACT_FORM)
  serviceId String?
  service   Service?   @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@index([status])
  @@index([createdAt])
  @@map("leads")
}

model Appointment {
  id        String            @id @default(cuid())
  name      String
  email     String
  phone     String
  date      DateTime
  slot      String
  topic     String?
  message   String?           @db.Text
  status    AppointmentStatus @default(PENDING)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  @@index([status])
  @@index([date])
  @@map("appointments")
}

model Article {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  excerpt     String
  content     String   @db.Text
  coverImage  String?
  category    String?
  tags        String[] @default([])
  published   Boolean  @default(true)
  publishedAt DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([published, publishedAt])
  @@map("articles")
}

model Simulation {
  id        String         @id @default(cuid())
  type      SimulationType
  inputs    Json
  results   Json
  leadEmail String?
  createdAt DateTime       @default(now())

  @@index([type])
  @@map("simulations")
}
