# PostgreSQL connection string.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/lr_patrimoine?schema=public"

# NextAuth — generate with `openssl rand -base64 32`
AUTH_SECRET=""
NEXTAUTH_URL="http://localhost:3000"

# Seed data — used once by `npm run db:seed` to create the first admin account.
ADMIN_EMAIL="admin@lr-patrimoine.fr"
ADMIN_PASSWORD=""
ADMIN_NAME="Ludovic Ruys"

# n8n webhook URL (production URL of your n8n Webhook node) — when set, every
# contact-form submission is forwarded here so an n8n workflow can email you.
N8N_LEAD_WEBHOOK_URL=""
